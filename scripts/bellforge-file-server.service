[Unit]
Description=BellForge Local File Server (serves signage client to Chromium)
After=network.target

[Service]
Type=simple
User=bellforge
Group=bellforge
WorkingDirectory=/opt/bellforge/client

ExecStart=/usr/bin/python3 -m http.server 8080

Restart=always
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=bellforge-file-server

[Install]
WantedBy=multi-user.target
