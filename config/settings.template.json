{
  "_comment": "Copy this file to settings.json on each Pi. Do not commit settings.json to git.",
  "update_base_url": "https://raw.githubusercontent.com/<USER>/BellForge/main",
  "poll_interval_seconds": 300,
  "install_dir": "/opt/bellforge",
  "staging_dir": "/opt/bellforge/.staging",
  "log_file": "/var/log/bellforge-updater.log",
  "max_retries": 3,
  "retry_delay_seconds": 20,
  "services_to_restart": [
    "bellforge-backend.service",
    "bellforge-client.service"
  ],
  "preserve_local_paths": [
    "config/settings.json",
    "config/client.env"
  ],
  "device_id": "main"
}
